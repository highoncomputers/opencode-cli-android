{
  "name": "opencode-cli-android",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "installGradle": true
    },
    "ghcr.io/devcontainers/features/android-sdk:1": {
      "version": "34",
      "buildToolsVersion": "34.0.0",
      "cmdlineToolsVersion": "12.0",
      "acceptLicenses": true
    }
  },
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md"]
    }
  },
  "postCreateCommand": "chmod +x /workspaces/opencode-cli-android/script/build-apk.sh && /workspaces/opencode-cli-android/script/build-apk.sh",
  "forwardPorts": [],
  "portsAttributes": {}
}
